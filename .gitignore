# Dependencies
node_modules/
python/
packages/

# Electron build output
dist-electron/
.electron-builder/

# Python bytecode / cache
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
*.egg-info/
.mypy_cache/
.ruff_cache/

# macOS / Windows junk
.DS_Store
Thumbs.db
Desktop.ini

# IDE / editor
.idea/
.vscode/
.cursor/

# App icons (iconset is intermediate; keep build/icon.png & build/icon.icns)
build/icon.iconset/

# Environment & secrets
.env
.env.*
!.env.example
API/.env
**/credentials.json
*.pem
*.key

# Runtime user data & generated output
output/
assets/
global_config.json

# User-specific data (keep tracked defaults like data/asset_library.json)
data/api_providers.json
data/conversations/
data/canvases/
data/update_backups/

# Local Python venv (dev fallback; packaged venv lives in userData)
venv/
.venv/
env/

# Self-restart scripts/logs
_self_restart.*

# npm / yarn debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
