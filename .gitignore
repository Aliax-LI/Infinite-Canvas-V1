# Dependencies
node_modules/
python/
packages/

# Electron build output
dist-electron/
.electron-builder/
frontend/dist/
test-results/
.audit/
# Python bytecode / cache
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
*.egg-info/
.mypy_cache/
.ruff_cache/

# macOS / Windows junk
.DS_Store
Thumbs.db
Desktop.ini

# IDE / editor
.idea/
.vscode/
.cursor/
.codex/
# App icons (iconset is intermediate; keep build/icon.png & build/icon.icns)
build/icon.iconset/

# Environment & secrets
.env
.env.*
!.env.example
API/.env
**/credentials.json
*.pem
*.key

# Runtime user data & generated output
output/
assets/
global_config.json
history.json
DESKTOP_BUILD_ID

# Local app data (DB, secrets, history, objects, conversations, config JSON)
# Bootstrapped on first run via ensure_data_dirs() / default_* helpers
data/

# Local Python venv (dev fallback; packaged venv lives in userData)
venv/
.venv/
env/
.recover/
# Self-restart scripts/logs
_self_restart.*

# npm / yarn debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
