{
  "name": "infinite-canvas-desktop",
  "version": "2026.07.6",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "description": "无限画布桌面应用",
  "main": "electron/main.js",
  "scripts": {
    "desktop": "node scripts/electron-mirror-env.js electron .",
    "electron": "node scripts/electron-mirror-env.js electron .",
    "dev": "concurrently -k \"npm run dev:frontend\" \"npm run dev:electron\"",
    "dev:backend": "python -m uvicorn backend.main:app --reload --host 127.0.0.1 --port 3000",
    "dev:frontend": "npm run dev -w frontend",
    "dev:electron": "wait-on http://127.0.0.1:5173 && cross-env USE_VITE=1 node scripts/electron-mirror-env.js electron .",
    "install:cn": "node scripts/electron-mirror-env.js npm install",
    "build:frontend": "npm run build -w frontend",
    "build:desktop": "npm run build:frontend && npm run dist",
    "test": "npm run test:all",
    "test:unit": "node --test tests/unit/electron/storage-setup.test.js tests/unit/electron/setup-sidebar.test.js && npm run test -w frontend && npm run validate-i18n -w frontend && pytest backend/tests/unit -q",
    "test:integration": "pytest backend/tests/integration -q",
    "test:electron": "npm run build:frontend && playwright test",
    "test:e2e": "npm run test:electron",
    "test:security": "bandit -r backend -x backend/tests && npm audit --registry=https://registry.npmjs.org --audit-level=high",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:electron && npm run test:security",
    "pack": "npm run prebuild:desktop && node scripts/electron-mirror-env.js electron-builder --dir",
    "dist": "npm run prebuild:desktop && node scripts/electron-mirror-env.js electron-builder",
    "dist:mac": "npm run prebuild:desktop && node scripts/electron-mirror-env.js electron-builder --mac dmg",
    "dist:win": "npm run prebuild:desktop && node scripts/electron-mirror-env.js electron-builder --win nsis zip",
    "postinstall": "node scripts/patch-electron-builder-resedit.js",
    "prebuild:desktop": "node scripts/write-desktop-build-id.js && node scripts/patch-electron-builder-resedit.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "concurrently": "^9.2.0",
    "cross-env": "^10.1.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.0.12",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.infinitecanvas.desktop",
    "productName": "无限画布",
    "publish": null,
    "artifactName": "${productName}-${version}.${ext}",
    "asar": false,
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".",
        "to": "app-source",
        "filter": [
          "backend/**",
          "frontend/dist/**",
          "pyproject.toml",
          "requirements.txt",
          "VERSION",
          "DESKTOP_BUILD_ID",
          "LICENSE",
          "workflows/**",
          "data/**",
          "API/**",
          "CLI/**",
          "tools/**",
          "!node_modules/**",
          "!dist-electron/**",
          "!python/**",
          "!packages/**",
          "!.git/**",
          "!.idea/**"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.graphics-design",
      "icon": "build/icon.icns",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false,
      "include": "build/installer.nsh",
      "runAfterFinish": true,
      "shortcutName": "无限画布",
      "uninstallDisplayName": "无限画布",
      "installerLanguages": [
        "zh_CN"
      ],
      "language": "2052"
    },
    "dmg": {
      "title": "无限画布"
    }
  }
}
